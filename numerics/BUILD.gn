import("../build/ave.gni")

group("numerics") {
  deps = [
    ":divide_round",
    ":exp_filter",
    ":mod_ops",
    ":moving_percentile_filter",
    ":percentile_filter",
    ":safe_compare",
    ":safe_conversions",
    ":safe_minmax",
    ":sequence_number_unwrapper",
    ":sequence_number_util",
  ]
}

ave_library("exp_filter") {
  sources = [
    "exp_filter.cc",
    "exp_filter.h",
  ]
}

ave_source_set("safe_conversions") {
  sources = [
    "safe_conversions.h",
    "safe_conversions_impl.h",
  ]
  deps = [ "..:checks" ]
}

ave_source_set("safe_compare") {
  sources = [
    "safe_compare.h",
    "safe_compare_impl.h",
  ]
  deps = [ "..:type_traits" ]
}

ave_source_set("safe_minmax") {
  sources = [ "safe_minmax.h" ]
  deps = [
    ":safe_compare",
    "..:checks",
    "..:type_traits",
  ]
}

ave_source_set("divide_round") {
  sources = [ "divide_round.h" ]
  deps = [
    ":safe_compare",
    "..:checks",
  ]
}

#ave_source_set("statistics") {
