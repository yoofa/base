#    "kahan_sum.h",
#    "statistics.h",
#  ]
#}

ave_library("mod_ops") {
  sources = [ "mod_ops.h" ]
  deps = [ "..:checks" ]
}

ave_library("percentile_filter") {
  sources = [ "percentile_filter.h" ]
  deps = [ "..:checks" ]
}

ave_library("moving_percentile_filter") {
  sources = [ "moving_percentile_filter.h" ]
  deps = [
    ":percentile_filter",
    "..:checks",
  ]
}

ave_library("sequence_number_util") {
  sources = [ "sequence_number_util.h" ]
  deps = [ ":mod_ops" ]
}

ave_library("sequence_number_unwrapper") {
  sources = [ "sequence_number_unwrapper.h" ]
  deps = [ ":sequence_number_util" ]
}

source_set("numerics_unittests_source") {
  testonly = true
  sources = [
    "divide_round_unittest.cc",
    "exp_filter_unittest.cc",
    "mod_ops_unittest.cc",
    "percentile_filter_unittest.cc",
    "safe_compare_unittest.cc",
    "safe_conversions_unittest.cc",
    "sequence_number_unwrapper_unittest.cc",
    "sequence_number_util_unittest.cc",
  ]
  deps = [
    ":numerics",
    "..:logging",
    "//test:test_support",
  ]
}
